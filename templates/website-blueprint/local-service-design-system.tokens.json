{
  "meta": {
    "name": "Local Service Enterprise Design System",
    "version": "1.0.0",
    "description": "Reusable token baseline for local service business websites"
  },
  "color": {
    "brand": {
      "primary": "#0E7490",
      "primaryHover": "#155E75",
      "secondary": "#F59E0B",
      "secondaryHover": "#D97706",
      "accent": "#16A34A"
    },
    "neutral": {
      "900": "#0F172A",
      "800": "#1E293B",
      "700": "#334155",
      "500": "#64748B",
      "300": "#CBD5E1",
      "100": "#F1F5F9",
      "0": "#FFFFFF"
    },
    "semantic": {
      "success": "#16A34A",
      "warning": "#F59E0B",
      "error": "#DC2626",
      "info": "#2563EB"
    },
    "text": {
      "primary": "#0F172A",
      "secondary": "#334155",
      "inverse": "#FFFFFF",
      "link": "#155E75"
    },
    "background": {
      "page": "#FFFFFF",
      "sectionAlt": "#F8FAFC",
      "card": "#FFFFFF",
      "overlay": "rgba(2, 6, 23, 0.65)"
    },
    "border": {
      "default": "#E2E8F0",
      "strong": "#94A3B8",
      "focus": "#2563EB"
    }
  },
  "typography": {
    "fontFamily": {
      "base": "Inter, system-ui, -apple-system, Segoe UI, Roboto, Arial, sans-serif",
      "heading": "Inter, system-ui, -apple-system, Segoe UI, Roboto, Arial, sans-serif"
    },
    "fontSize": {
      "xs": "12px",
      "sm": "14px",
      "base": "16px",
      "lg": "18px",
      "xl": "20px",
      "2xl": "24px",
      "3xl": "30px",
      "4xl": "36px",
      "5xl": "48px"
    },
    "lineHeight": {
      "tight": 1.2,
      "snug": 1.35,
      "normal": 1.5,
      "relaxed": 1.7
    },
    "fontWeight": {
      "regular": 400,
      "medium": 500,
      "semibold": 600,
      "bold": 700
    }
  },
  "spacing": {
    "0": "0px",
    "1": "4px",
    "2": "8px",
    "3": "12px",
    "4": "16px",
    "5": "20px",
    "6": "24px",
    "8": "32px",
    "10": "40px",
    "12": "48px",
    "16": "64px",
    "20": "80px",
    "24": "96px"
  },
  "radius": {
    "sm": "6px",
    "md": "10px",
    "lg": "14px",
    "xl": "18px",
    "pill": "9999px"
  },
  "shadow": {
    "sm": "0 1px 2px rgba(15, 23, 42, 0.08)",
    "md": "0 8px 20px rgba(15, 23, 42, 0.10)",
    "lg": "0 20px 40px rgba(15, 23, 42, 0.14)"
  },
  "layout": {
    "maxWidth": {
      "content": "1200px",
      "text": "740px",
      "wide": "1320px"
    },
    "breakpoints": {
      "sm": "640px",
      "md": "768px",
      "lg": "1024px",
      "xl": "1280px",
      "2xl": "1536px"
    }
  },
  "motion": {
    "duration": {
      "fast": "120ms",
      "base": "180ms",
      "slow": "280ms"
    },
    "easing": {
      "standard": "cubic-bezier(0.2, 0, 0, 1)",
      "entrance": "cubic-bezier(0, 0, 0.2, 1)",
      "exit": "cubic-bezier(0.4, 0, 1, 1)"
    }
  },
  "components": {
    "button": {
      "height": {
        "sm": "36px",
        "md": "44px",
        "lg": "52px"
      },
      "paddingX": {
        "sm": "14px",
        "md": "18px",
        "lg": "22px"
      },
      "focusRing": "0 0 0 3px rgba(37, 99, 235, 0.35)"
    },
    "input": {
      "height": "46px",
      "border": "1px solid #E2E8F0",
      "focusBorder": "1px solid #2563EB"
    },
    "card": {
      "padding": "24px",
      "radius": "14px",
      "shadow": "0 8px 20px rgba(15, 23, 42, 0.10)"
    }
  },
  "accessibility": {
    "minimumContrast": {
      "normalText": "4.5:1",
      "largeText": "3:1"
    },
    "focusVisibleRequired": true,
    "minTapTarget": "44px"
  }
}
