{
  "name": "fiverr-bot",
  "version": "1.0.0",
  "description": "Automated Fiverr gig posting and order management bot",
  "main": "fiverr-bot.js",
  "scripts": {
    "setup": "npm install playwright && npx playwright install chromium",
    "post": "node fiverr-bot.js --action post",
    "monitor": "node fiverr-bot.js --action monitor",
    "status": "node fiverr-bot.js --action status",
    "logs": "tail -f fiverr-bot.log",
    "test": "node fiverr-bot.js --action test"
  },
  "keywords": [
    "fiverr",
    "automation",
    "bot",
    "playwright"
  ],
  "author": "Cliff",
  "license": "MIT",
  "dependencies": {
    "@askjo/camofox-browser": "^1.3.1",
    "edge-tts": "^1.0.1",
    "nodemailer": "^8.0.1",
    "openai": "^6.25.0",
    "playwright": "^1.58.2",
    "playwright-extra": "^4.3.6",
    "puppeteer-extra-plugin-stealth": "^2.11.2"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
