# ============================================================
# NorthStar Synergy — Environment Variables
# Copy this file to .env.local and fill in your values
# ============================================================

# --- Authentication (REQUIRED for production) ---
AUTH_SECRET=             # Random 32+ char string for JWT signing (openssl rand -base64 32)
ADMIN_EMAIL=admin@northstarsynergy.com
ADMIN_PASSWORD=          # Change from default before deploying

# --- Database (Supabase) ---
NEXT_PUBLIC_SUPABASE_URL=    # https://xxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=   # service_role key from Supabase dashboard

# --- Square (Restaurant Payment Processing) ---
SQUARE_APPLICATION_ID=
SQUARE_ACCESS_TOKEN=
SQUARE_LOCATION_ID=
SQUARE_ENVIRONMENT=sandbox   # "sandbox" or "production"
SQUARE_WEBHOOK_SIGNATURE_KEY=
SQUARE_WEBHOOK_URL=          # https://yourdomain.com/api/webhooks/square

# Square (client-side — must be NEXT_PUBLIC_)
NEXT_PUBLIC_SQUARE_APPLICATION_ID=
NEXT_PUBLIC_SQUARE_LOCATION_ID=
NEXT_PUBLIC_SQUARE_ENVIRONMENT=sandbox

# --- Stripe (NorthStar SaaS Billing) ---
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=       # whsec_xxx from Stripe dashboard
STRIPE_PRICE_STARTER=        # price_xxx for $99/mo Starter plan
STRIPE_PRICE_GROWTH=         # price_xxx for $149/mo Growth plan
STRIPE_PRICE_PRO=            # price_xxx for $249/mo Pro plan

# --- Resend (Email Notifications & Outreach) ---
RESEND_API_KEY=              # re_xxx from resend.com
RESEND_WEBHOOK_SECRET=       # Webhook signing secret from Resend dashboard
SUPPORT_FROM_EMAIL=support@northstarsynergy.com
CONTACT_FORM_EMAIL=hello@northstarsynergy.com

# --- Twilio (SMS Notifications) ---
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=         # +1xxxxxxxxxx

# --- Cron / Automation ---
CRON_SECRET=                 # Secret for Vercel Cron job authentication
DIGEST_RECIPIENT_EMAIL=      # Email to receive weekly digest (e.g. your email)

# --- Vercel (Preview Site Deployment) ---
VERCEL_TOKEN=                # Personal access token from vercel.com/account/tokens

# --- Lob (Physical Postcards) ---
LOB_API_KEY=                 # test_xxx or live_xxx from lob.com

# --- Outreach Pipeline ---
WARMUP_START_DATE=           # ISO date (YYYY-MM-DD) when domain warmup started
GOOGLE_PLACES_API_KEY=       # For restaurant discovery scraper

# --- Google Maps (optional, for restaurant location embed) ---
NEXT_PUBLIC_GOOGLE_MAPS_KEY=
